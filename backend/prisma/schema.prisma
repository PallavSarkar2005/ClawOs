generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  name                   String
  email                  String         @unique
  username               String?        @unique
  passwordHash           String?
  githubId               String?
  avatar                 String?
  emailVerified          Boolean        @default(false)
  emailVerificationToken String?        @unique
  passwordResetToken     String?        @unique
  passwordResetExpires   DateTime?
  role                   String         @default("user")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  lastLogin              DateTime?
  lastPasswordChange     DateTime?
  isActive               Boolean        @default(true)

  conversations          Conversation[]
  memories               Memory[]
  skills                 Skill[]
  workflows              Workflow[]
  documents              Document[]
  settings               Setting?
  refreshTokens          RefreshToken[]
  sessions               Session[]
  projects               Project[]
  integrations           Integration[]
  memoryCollections      MemoryCollection[]
  indexJobs              IndexJob[]
  memoryAccessLogs       MemoryAccessLog[]
  agentExecutions        AgentExecution[]
}

model Conversation {
  id         String    @id @default(uuid())
  title      String
  createdAt  DateTime  @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])

  messages         Message[]
  memories         Memory[]
  agentExecutions  AgentExecution[]
}

model Message {
  id             String       @id @default(uuid())
  role           String
  content        String
  createdAt      DateTime     @default(now())
  citations      Json?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Memory {
  id             String    @id @default(uuid())
  content        String
  ownerId        String
  scope          String    @default("USER")
  importance     Float     @default(0.5)
  pinned         Boolean   @default(false)
  confidence     Float     @default(1.0)
  frequency      Int       @default(0)
  decay          Float     @default(0.0)
  source         String?
  tags           String[]  @default([])
  metadata       Json      @default("{}")
  relationships  Json      @default("[]")
  embedding      Json?
  embeddingModel String?
  embeddingDim   Int?
  contentHash    String?
  version        Int       @default(1)
  score          Float     @default(0.5)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastAccessed   DateTime  @default(now())

  projectId      String?
  conversationId String?
  agentType      String?
  workflowId     String?
  documentId     String?
  workspaceId    String?
  collectionId   String?

  owner          User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  document       Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  collection     MemoryCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  versions       MemoryVersion[]
  graphFrom      MemoryEdge[]  @relation("EdgeFrom")
  graphTo        MemoryEdge[]  @relation("EdgeTo")
  accessLogs     MemoryAccessLog[]

  @@index([ownerId, scope])
  @@index([ownerId, deletedAt])
  @@index([ownerId, pinned])
  @@index([ownerId, lastAccessed])
  @@index([projectId])
  @@index([documentId])
  @@index([contentHash])
  @@index([agentType])
}

model MemoryVersion {
  id        String   @id @default(uuid())
  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  content   String
  version   Int
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([memoryId])
  @@unique([memoryId, version])
}

model MemoryEdge {
  id         String   @id @default(uuid())
  fromId     String
  toId       String
  type       String
  weight     Float    @default(1.0)
  metadata   Json     @default("{}")
  ownerId    String
  createdAt  DateTime @default(now())

  from       Memory   @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to         Memory   @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@index([ownerId])
  @@unique([fromId, toId, type])
}

model MemoryCollection {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  isShared    Boolean  @default(false)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memories    Memory[]
  items       MemoryCollectionItem[]

  @@index([ownerId])
}

model MemoryCollectionItem {
  id           String           @id @default(uuid())
  collectionId String
  memoryId     String
  collection   MemoryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([collectionId, memoryId])
  @@index([memoryId])
}

model MemoryAccessLog {
  id        String   @id @default(uuid())
  memoryId  String?
  ownerId   String
  action    String
  query     String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  memory    Memory?  @relation(fields: [memoryId], references: [id], onDelete: SetNull)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([memoryId])
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  description String
  prompt      String

  enabled     Boolean  @default(true)
  category    String   @default("Custom")
  usageCount  Int      @default(0)

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String
  prompt      String

  enabled     Boolean  @default(true)

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id             String   @id @default(uuid())
  name           String
  path           String
  content        String   @default("")
  mimeType       String?
  fileType       String?
  fileSize       Int      @default(0)
  status         String   @default("pending")
  indexProgress  Float    @default(0)
  indexError     String?
  pageCount      Int?
  tokenCount     Int      @default(0)
  chunkCount     Int      @default(0)
  contentHash    String?
  metadata       Json     @default("{}")
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  workspaceId    String?

  conversations  Conversation[]
  chunks         DocumentChunk[]
  memories       Memory[]
  indexJobs      IndexJob[]

  @@index([userId, deletedAt])
  @@index([userId, status])
  @@index([contentHash])
}

model DocumentChunk {
  id             String   @id @default(uuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content        String
  chunkIndex     Int
  tokenCount     Int      @default(0)
  contentHash    String?
  embedding      Json?
  embeddingModel String?
  embeddingDim   Int?
  pageStart      Int?
  pageEnd        Int?
  lineStart      Int?
  lineEnd        Int?
  heading        String?
  chunkType      String   @default("semantic")
  metadata       Json     @default("{}")
  parentChunkId  String?
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([documentId, chunkIndex])
  @@index([documentId, deletedAt])
  @@index([contentHash])
  @@unique([documentId, chunkIndex, version])
}

model IndexJob {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type        String    @default("index")
  status      String    @default("queued")
  progress    Float     @default(0)
  stage       String?
  error       String?
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  payload     Json      @default("{}")
  result      Json?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([documentId])
}

model Setting {
  id               String   @id @default(cuid())

  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultProvider  String   @default("openrouter")
  defaultModel     String   @default("meta-llama/llama-3.3-70b-instruct")

  autoMemorySave   Boolean  @default(true)
  autoSkillRouting Boolean  @default(true)
  webSearchDefault Boolean  @default(false)
  streamingEnabled Boolean  @default(true)

  temperature      Float    @default(0.7)
  maxContext       Int      @default(20)
  maxTokens        Int      @default(4096)

  embeddingProvider String  @default("openrouter")
  embeddingModel    String  @default("openai/text-embedding-3-small")

  appearance       Json     @default("{\"theme\":\"dark\",\"accentColor\":\"#F15B42\",\"layout\":\"comfortable\",\"sidebarCollapsed\":false,\"fontSize\":\"medium\"}")
  notifications    Json     @default("{\"emailNotifications\":true,\"aiTaskNotifications\":true,\"workflowCompletion\":true,\"securityAlerts\":true,\"marketingEmails\":false}")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Integration {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  apiKeyEncrypted String
  keyHint         String
  status          String    @default("connected")
  lastTestedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  browser    String?
  os         String?
  device     String?  @default("desktop")
  location   String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Project {
  id           String            @id @default(uuid())
  name         String
  description  String?
  framework    String            @default("react")
  status       String            @default("idle")
  isFavorite   Boolean           @default(false)
  sortOrder    Int               @default(0)
  lastOpenedAt DateTime?
  layout       Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        ProjectFile[]
  logs         ProjectLog[]
  executions   AiExecution[]
  diffs        ProjectDiff[]
  terminals    TerminalSession[]
  runs         CodeRun[]
  editorTabs   EditorTab[]
}

model TerminalSession {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String   @default("bash")
  cwd       String?
  cols      Int      @default(80)
  rows      Int      @default(24)
  history   Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model CodeRun {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  command    String
  status     String   @default("running")
  exitCode   Int?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  durationMs Int?
  output     String   @default("")
  projectType String?

  @@index([projectId])
}

model EditorTab {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileId    String
  isActive  Boolean  @default(false)
  viewGroup String   @default("main")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@unique([projectId, fileId, viewGroup])
}

model ProjectFile {
  id        String        @id @default(uuid())
  name      String
  path      String
  content   String        @default("")
  isFolder  Boolean       @default(false)
  parentId  String?
  parent    ProjectFile?  @relation("FileTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProjectFile[] @relation("FileTree")
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model ProjectLog {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  source    String   @default("system")
  message   String
  createdAt DateTime @default(now())

  @@index([projectId])
}

model AiExecution {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       String   @default("running")
  currentStage String?
  stages       Json     @default("[]")
  summary      String?
  tokensUsed   Int      @default(0)
  promptTokens Int      @default(0)
  completionTokens Int  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
}

/// Multi-agent runtime execution (Phase 2)
model AgentExecution {
  id              String   @id @default(uuid())
  userId          String
  conversationId  String?
  projectId       String?
  messageId       String?
  status          String   @default("QUEUED")
  intent          String?
  plan            Json?
  agentTree       Json     @default("[]")
  finalOutput     String?
  error           String?
  cancelRequested Boolean  @default(false)
  maxRetries      Int      @default(2)
  timeoutMs       Int      @default(300000)
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  contextSize     Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  steps           AgentStep[]
  logs            AgentLog[]
  toolCalls       AgentToolCall[]
  metrics         AgentMetric[]
  transitions     AgentStateTransition[]

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([status])
  @@index([projectId])
}

model AgentStep {
  id               String   @id @default(uuid())
  executionId      String
  execution        AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  taskId           String?
  agentType        String
  status           String   @default("pending")
  priority         Int      @default(0)
  complexity       String?
  dependencies     Json     @default("[]")
  requiredTools    Json     @default("[]")
  expectedOutputs  Json     @default("[]")
  input            Json?
  output           String?
  reasoning        String?
  prompt           String?
  error            String?
  retryCount       Int      @default(0)
  maxRetries       Int      @default(2)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0)
  startedAt        DateTime?
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  toolCalls        AgentToolCall[]
  logs             AgentLog[]

  @@index([executionId, status])
  @@index([agentType])
}

model AgentToolCall {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId      String?
  step        AgentStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  agentType   String?
  toolName    String
  arguments   Json     @default("{}")
  result      Json?
  status      String   @default("pending")
  error       String?
  durationMs  Int?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([executionId])
  @@index([stepId])
  @@index([toolName])
}

model AgentLog {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId      String?
  step        AgentStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  level       String   @default("info")
  agentType   String?
  event       String?
  message     String
  data        Json?
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
  @@index([stepId])
}

model AgentMetric {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  key         String
  value       Float
  unit        String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([executionId, key])
}

model AgentStateTransition {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  fromState   String?
  toState     String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
}

model ProjectDiff {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileId    String?
  filePath  String
  before    String   @default("")
  after     String   @default("")
  status    String   @default("pending")
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}
