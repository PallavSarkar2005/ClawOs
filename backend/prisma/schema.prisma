generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  name                   String
  email                  String         @unique
  username               String?        @unique
  passwordHash           String?
  githubId               String?
  avatar                 String?
  emailVerified          Boolean        @default(false)
  emailVerificationToken String?        @unique
  passwordResetToken     String?        @unique
  passwordResetExpires   DateTime?
  role                   String         @default("user")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  lastLogin              DateTime?
  lastPasswordChange     DateTime?
  isActive               Boolean        @default(true)

  conversations          Conversation[]
  memories               Memory[]
  skills                 Skill[]
  workflows              Workflow[]
  workflowTemplates      WorkflowTemplate[]
  workflowExecutions     WorkflowExecution[]
  documents              Document[]
  settings               Setting?
  refreshTokens          RefreshToken[]
  sessions               Session[]
  projects               Project[]
  integrations           Integration[]
  memoryCollections      MemoryCollection[]
  indexJobs              IndexJob[]
  memoryAccessLogs       MemoryAccessLog[]
  agentExecutions        AgentExecution[]
  toolPermissions        ToolPermission[]
  toolUsages             ToolUsage[]
  contextSessions        ContextSession[]
  knowledgeNodes         KnowledgeNode[]
  knowledgeCollections   KnowledgeCollection[]
  searchHistory          SearchHistory[]
  knowledgeJobs          KnowledgeJob[]
  repositories           Repository[]
  obsTraces              ObsTrace[]
  obsAlerts              ObsAlert[]
  obsReplays             ObsReplay[]
  obsMetrics             ObsMetric[]
  obsSnapshots           ObsExecutionSnapshot[]
}

model Conversation {
  id         String    @id @default(uuid())
  title      String
  createdAt  DateTime  @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])

  messages         Message[]
  memories         Memory[]
  agentExecutions  AgentExecution[]
}

model Message {
  id             String       @id @default(uuid())
  role           String
  content        String
  createdAt      DateTime     @default(now())
  citations      Json?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Memory {
  id             String    @id @default(uuid())
  content        String
  ownerId        String
  scope          String    @default("USER")
  importance     Float     @default(0.5)
  pinned         Boolean   @default(false)
  confidence     Float     @default(1.0)
  frequency      Int       @default(0)
  decay          Float     @default(0.0)
  source         String?
  tags           String[]  @default([])
  metadata       Json      @default("{}")
  relationships  Json      @default("[]")
  embedding      Json?
  embeddingModel String?
  embeddingDim   Int?
  contentHash    String?
  version        Int       @default(1)
  score          Float     @default(0.5)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastAccessed   DateTime  @default(now())

  projectId      String?
  conversationId String?
  agentType      String?
  workflowId     String?
  documentId     String?
  workspaceId    String?
  collectionId   String?

  owner          User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  document       Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  collection     MemoryCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  versions       MemoryVersion[]
  graphFrom      MemoryEdge[]  @relation("EdgeFrom")
  graphTo        MemoryEdge[]  @relation("EdgeTo")
  accessLogs     MemoryAccessLog[]

  @@index([ownerId, scope])
  @@index([ownerId, deletedAt])
  @@index([ownerId, pinned])
  @@index([ownerId, lastAccessed])
  @@index([projectId])
  @@index([documentId])
  @@index([contentHash])
  @@index([agentType])
}

model MemoryVersion {
  id        String   @id @default(uuid())
  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  content   String
  version   Int
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([memoryId])
  @@unique([memoryId, version])
}

model MemoryEdge {
  id         String   @id @default(uuid())
  fromId     String
  toId       String
  type       String
  weight     Float    @default(1.0)
  metadata   Json     @default("{}")
  ownerId    String
  createdAt  DateTime @default(now())

  from       Memory   @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to         Memory   @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@index([ownerId])
  @@unique([fromId, toId, type])
}

model MemoryCollection {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  isShared    Boolean  @default(false)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memories    Memory[]
  items       MemoryCollectionItem[]

  @@index([ownerId])
}

model MemoryCollectionItem {
  id           String           @id @default(uuid())
  collectionId String
  memoryId     String
  collection   MemoryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([collectionId, memoryId])
  @@index([memoryId])
}

model MemoryAccessLog {
  id        String   @id @default(uuid())
  memoryId  String?
  ownerId   String
  action    String
  query     String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  memory    Memory?  @relation(fields: [memoryId], references: [id], onDelete: SetNull)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([memoryId])
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  description String
  prompt      String

  enabled     Boolean  @default(true)
  category    String   @default("Custom")
  usageCount  Int      @default(0)

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id            String   @id @default(uuid())
  name          String
  description   String   @default("")
  prompt        String   @default("")
  definition    Json     @default("{\"nodes\":[],\"edges\":[],\"groups\":[],\"viewport\":{\"x\":0,\"y\":0,\"zoom\":1}}")
  status        String   @default("draft")
  version       Int      @default(1)
  publishedAt   DateTime?
  enabled       Boolean  @default(true)
  projectId     String?
  tags          String[] @default([])
  variables     Json     @default("{}")
  secrets       Json     @default("{}")
  settings      Json     @default("{}")
  permissions   Json     @default("{}")
  isTemplate    Boolean  @default(false)
  isShared      Boolean  @default(false)
  shareToken    String?  @unique
  clonedFromId  String?
  metadata      Json     @default("{}")
  lastRunAt     DateTime?
  runCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  versions      WorkflowVersion[]
  nodes         WorkflowNode[]
  edges         WorkflowEdge[]
  executions    WorkflowExecution[]
  triggers      WorkflowTrigger[]
  schedules     WorkflowSchedule[]
  metrics       WorkflowMetric[]

  @@index([userId, status])
  @@index([userId, enabled])
  @@index([userId, createdAt])
  @@index([projectId])
  @@index([isTemplate])
}

model WorkflowVersion {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version     Int
  definition  Json
  variables   Json     @default("{}")
  changelog   String?
  publishedBy String?
  createdAt   DateTime @default(now())

  @@unique([workflowId, version])
  @@index([workflowId, createdAt])
}

model WorkflowNode {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeKey     String
  type        String
  label       String   @default("")
  config      Json     @default("{}")
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  width       Float?
  height      Float?
  groupId     String?
  retryPolicy Json     @default("{}")
  timeoutMs   Int?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workflowId, nodeKey])
  @@index([workflowId, type])
}

model WorkflowEdge {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  edgeKey     String
  sourceKey   String
  targetKey   String
  sourceHandle String?
  targetHandle String?
  label       String?
  condition   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@unique([workflowId, edgeKey])
  @@index([workflowId, sourceKey])
  @@index([workflowId, targetKey])
}

model WorkflowExecution {
  id              String    @id @default(uuid())
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  version         Int       @default(1)
  status          String    @default("QUEUED")
  triggerType     String    @default("manual")
  triggerData     Json      @default("{}")
  definition      Json      @default("{}")
  inputs          Json      @default("{}")
  outputs         Json      @default("{}")
  variables       Json      @default("{}")
  context         Json      @default("{}")
  currentNodeKeys String[]  @default([])
  error           String?
  errorNodeKey    String?
  cancelRequested Boolean   @default(false)
  pauseRequested   Boolean   @default(false)
  approvalPending Json?
  checkpoint      Json?
  metrics         Json      @default("{}")
  priority        Int       @default(0)
  concurrencyKey  String?
  parentExecutionId String?
  projectId       String?
  conversationId  String?
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  nodes           WorkflowExecutionNode[]
  artifacts       WorkflowArtifact[]
  checkpoints     WorkflowCheckpoint[]
  metricsLog      WorkflowMetric[]

  @@index([workflowId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([status, priority])
  @@index([parentExecutionId])
}

model WorkflowExecutionNode {
  id            String   @id @default(uuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeKey       String
  nodeType      String
  label         String   @default("")
  status        String   @default("PENDING")
  attempt       Int      @default(0)
  maxAttempts   Int      @default(1)
  inputs        Json     @default("{}")
  outputs       Json     @default("{}")
  error         String?
  logs          Json     @default("[]")
  toolCalls     Json     @default("[]")
  agentActivity Json     @default("{}")
  tokensUsed    Int      @default(0)
  latencyMs     Int?
  memoryBytes   Int?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([executionId, nodeKey, attempt])
  @@index([executionId, status])
  @@index([executionId, nodeKey])
}

model WorkflowArtifact {
  id          String   @id @default(uuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeKey     String?
  name        String
  type        String   @default("json")
  mimeType    String?
  content     String?
  data        Json?
  sizeBytes   Int      @default(0)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
  @@index([executionId, nodeKey])
}

model WorkflowCheckpoint {
  id          String   @id @default(uuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeKey     String?
  state       Json
  variables   Json     @default("{}")
  completedKeys String[] @default([])
  label       String?
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
}

model WorkflowTrigger {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type        String
  name        String   @default("")
  enabled     Boolean  @default(true)
  config      Json     @default("{}")
  webhookSecret String?
  lastFiredAt DateTime?
  fireCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workflowId, type])
  @@index([type, enabled])
}

model WorkflowTemplate {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  category    String   @default("general")
  definition  Json
  variables   Json     @default("{}")
  tags        String[] @default([])
  isBuiltin   Boolean  @default(false)
  usageCount  Int      @default(0)
  thumbnail   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isBuiltin])
  @@index([userId])
}

model WorkflowSchedule {
  id              String    @id @default(uuid())
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cron            String?
  timezone        String    @default("UTC")
  enabled         Boolean   @default(true)
  oneShotAt       DateTime?
  delayMs         Int?
  inputs          Json      @default("{}")
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  lastStatus      String?
  missedRecovery  Boolean   @default(true)
  runCount        Int       @default(0)
  maxRuns         Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([enabled, nextRunAt])
  @@index([workflowId])
}

model WorkflowMetric {
  id          String   @id @default(uuid())
  workflowId  String?
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  executionId String?
  execution   WorkflowExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  name        String
  value       Float
  unit        String?
  tags        Json     @default("{}")
  recordedAt  DateTime @default(now())

  @@index([workflowId, name, recordedAt])
  @@index([executionId, recordedAt])
}

model Document {
  id             String   @id @default(uuid())
  name           String
  path           String
  content        String   @default("")
  mimeType       String?
  fileType       String?
  fileSize       Int      @default(0)
  status         String   @default("pending")
  indexProgress  Float    @default(0)
  indexError     String?
  pageCount      Int?
  tokenCount     Int      @default(0)
  chunkCount     Int      @default(0)
  contentHash    String?
  metadata       Json     @default("{}")
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  workspaceId    String?

  conversations  Conversation[]
  chunks         DocumentChunk[]
  memories       Memory[]
  indexJobs      IndexJob[]

  @@index([userId, deletedAt])
  @@index([userId, status])
  @@index([contentHash])
}

model DocumentChunk {
  id             String   @id @default(uuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content        String
  chunkIndex     Int
  tokenCount     Int      @default(0)
  contentHash    String?
  embedding      Json?
  embeddingModel String?
  embeddingDim   Int?
  pageStart      Int?
  pageEnd        Int?
  lineStart      Int?
  lineEnd        Int?
  heading        String?
  chunkType      String   @default("semantic")
  metadata       Json     @default("{}")
  parentChunkId  String?
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([documentId, chunkIndex])
  @@index([documentId, deletedAt])
  @@index([contentHash])
  @@unique([documentId, chunkIndex, version])
}

model IndexJob {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type        String    @default("index")
  status      String    @default("queued")
  progress    Float     @default(0)
  stage       String?
  error       String?
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  payload     Json      @default("{}")
  result      Json?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([documentId])
}

model Setting {
  id               String   @id @default(cuid())

  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultProvider  String   @default("openrouter")
  defaultModel     String   @default("meta-llama/llama-3.3-70b-instruct")

  autoMemorySave   Boolean  @default(true)
  autoSkillRouting Boolean  @default(true)
  webSearchDefault Boolean  @default(false)
  streamingEnabled Boolean  @default(true)

  temperature      Float    @default(0.7)
  maxContext       Int      @default(20)
  maxTokens        Int      @default(4096)

  embeddingProvider String  @default("openrouter")
  embeddingModel    String  @default("openai/text-embedding-3-small")

  appearance       Json     @default("{\"theme\":\"dark\",\"accentColor\":\"#F15B42\",\"layout\":\"comfortable\",\"sidebarCollapsed\":false,\"fontSize\":\"medium\"}")
  notifications    Json     @default("{\"emailNotifications\":true,\"aiTaskNotifications\":true,\"workflowCompletion\":true,\"securityAlerts\":true,\"marketingEmails\":false}")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Integration {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  apiKeyEncrypted String
  keyHint         String
  status          String    @default("connected")
  lastTestedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  browser    String?
  os         String?
  device     String?  @default("desktop")
  location   String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Project {
  id           String            @id @default(uuid())
  name         String
  description  String?
  framework    String            @default("react")
  status       String            @default("idle")
  isFavorite   Boolean           @default(false)
  sortOrder    Int               @default(0)
  lastOpenedAt DateTime?
  layout       Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        ProjectFile[]
  logs         ProjectLog[]
  executions   AiExecution[]
  diffs        ProjectDiff[]
  terminals    TerminalSession[]
  runs         CodeRun[]
  editorTabs   EditorTab[]
  repository   Repository?
}

model TerminalSession {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String   @default("bash")
  cwd       String?
  cols      Int      @default(80)
  rows      Int      @default(24)
  history   Json     @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model CodeRun {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  command    String
  status     String   @default("running")
  exitCode   Int?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  durationMs Int?
  output     String   @default("")
  projectType String?

  @@index([projectId])
}

model EditorTab {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileId    String
  isActive  Boolean  @default(false)
  viewGroup String   @default("main")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@unique([projectId, fileId, viewGroup])
}

model ProjectFile {
  id        String        @id @default(uuid())
  name      String
  path      String
  content   String        @default("")
  isFolder  Boolean       @default(false)
  parentId  String?
  parent    ProjectFile?  @relation("FileTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProjectFile[] @relation("FileTree")
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([projectId])
  @@index([parentId])
}

model ProjectLog {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  source    String   @default("system")
  message   String
  createdAt DateTime @default(now())

  @@index([projectId])
}

model AiExecution {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       String   @default("running")
  currentStage String?
  stages       Json     @default("[]")
  summary      String?
  tokensUsed   Int      @default(0)
  promptTokens Int      @default(0)
  completionTokens Int  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
}

/// Multi-agent runtime execution (Phase 2)
model AgentExecution {
  id              String   @id @default(uuid())
  userId          String
  conversationId  String?
  projectId       String?
  messageId       String?
  status          String   @default("QUEUED")
  intent          String?
  plan            Json?
  agentTree       Json     @default("[]")
  finalOutput     String?
  error           String?
  cancelRequested Boolean  @default(false)
  maxRetries      Int      @default(2)
  timeoutMs       Int      @default(300000)
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  contextSize     Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  steps           AgentStep[]
  logs            AgentLog[]
  toolCalls       AgentToolCall[]
  metrics         AgentMetric[]
  transitions     AgentStateTransition[]

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([status])
  @@index([projectId])
}

model AgentStep {
  id               String   @id @default(uuid())
  executionId      String
  execution        AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  taskId           String?
  agentType        String
  status           String   @default("pending")
  priority         Int      @default(0)
  complexity       String?
  dependencies     Json     @default("[]")
  requiredTools    Json     @default("[]")
  expectedOutputs  Json     @default("[]")
  input            Json?
  output           String?
  reasoning        String?
  prompt           String?
  error            String?
  retryCount       Int      @default(0)
  maxRetries       Int      @default(2)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0)
  startedAt        DateTime?
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  toolCalls        AgentToolCall[]
  logs             AgentLog[]

  @@index([executionId, status])
  @@index([agentType])
}

model AgentToolCall {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId      String?
  step        AgentStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  agentType   String?
  toolName    String
  arguments   Json     @default("{}")
  result      Json?
  status      String   @default("pending")
  error       String?
  durationMs  Int?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([executionId])
  @@index([stepId])
  @@index([toolName])
}

model AgentLog {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId      String?
  step        AgentStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  level       String   @default("info")
  agentType   String?
  event       String?
  message     String
  data        Json?
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
  @@index([stepId])
}

model AgentMetric {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  key         String
  value       Float
  unit        String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([executionId, key])
}

model AgentStateTransition {
  id          String   @id @default(uuid())
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  fromState   String?
  toState     String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
}

/// Phase 3 — Production Tool Calling Platform
model Tool {
  id          String   @id
  name        String
  description String
  category    String
  version     String   @default("1.0.0")
  schema      Json     @default("{}")
  permissions Json     @default("[]")
  timeout     Int      @default(30000)
  retries     Int      @default(1)
  source      String   @default("builtin")
  pluginId    String?
  mcpServerId String?
  enabled     Boolean  @default(true)
  dangerous   Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics     ToolMetric[]
  usages      ToolUsage[]

  @@index([category])
  @@index([source])
  @@index([enabled])
}

model ToolExecution {
  id               String   @id @default(uuid())
  toolId           String
  toolVersion      String?
  userId           String?
  agentExecutionId String?
  agentStepId      String?
  agentType        String?
  status           String   @default("pending")
  inputs           Json     @default("{}")
  validatedArgs    Json     @default("{}")
  output           Json?
  error            String?
  errorCode        String?
  durationMs       Int?
  latencyMs        Int?
  retries          Int      @default(0)
  cached           Boolean  @default(false)
  tokenUsage       Int      @default(0)
  cost             Float    @default(0)
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  createdAt        DateTime @default(now())

  logs             ToolLog[]

  @@index([toolId, createdAt])
  @@index([userId, createdAt])
  @@index([agentExecutionId])
  @@index([status])
}

model ToolPermission {
  id          String   @id @default(uuid())
  toolId      String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentType   String?
  executionId String?
  required    Json     @default("[]")
  granted     Json     @default("[]")
  allowed     Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([toolId, createdAt])
  @@index([userId, createdAt])
}

model ToolMetric {
  id        String   @id @default(uuid())
  toolId    String?
  tool      Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  key       String
  value     Float
  unit      String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([toolId, key])
  @@index([createdAt])
}

model ToolLog {
  id          String   @id @default(uuid())
  executionId String
  execution   ToolExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  toolId      String?
  level       String   @default("info")
  message     String
  data        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([executionId, createdAt])
  @@index([toolId])
}

model ToolUsage {
  id         String   @id @default(uuid())
  toolId     String?
  tool       Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  durationMs Int      @default(0)
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([toolId, createdAt])
  @@index([userId, createdAt])
}

model ProjectDiff {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileId    String?
  filePath  String
  before    String   @default("")
  after     String   @default("")
  status    String   @default("pending")
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

/// Phase 4 — Production Context Manager
model ContextSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId   String?
  projectId        String?
  agentExecutionId String?
  agentType        String?
  query            String
  modelLimit       Int      @default(128000)
  tokenBudget      Int      @default(6000)
  usedTokens       Int      @default(0)
  compressionRatio Float    @default(1.0)
  allocation       Json     @default("{}")
  dropped          Json     @default("[]")
  reasoningPath    Json     @default("[]")
  graph            Json     @default("{}")
  status           String   @default("built")
  durationMs       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  retrieved        RetrievedContext[]
  scores           ContextScore[]
  summaries        ContextSummary[]
  compressions     CompressionHistory[]
  metrics          RankingMetrics[]

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([agentExecutionId])
  @@index([projectId])
  @@index([agentType])
}

model RetrievedContext {
  id          String   @id @default(uuid())
  sessionId   String
  session     ContextSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  source      String
  type        String
  sourceId    String?
  content     String
  score       Float    @default(0)
  reason      String?
  tokenCount  Int      @default(0)
  selected    Boolean  @default(true)
  metadata    Json     @default("{}")
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([sessionId, selected])
  @@index([source, type])
  @@index([sourceId])
}

model ContextScore {
  id              String   @id @default(uuid())
  sessionId       String
  session         ContextSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemKey         String
  similarity      Float    @default(0)
  recency         Float    @default(0)
  importance      Float    @default(0)
  frequency       Float    @default(0)
  confidence      Float    @default(0)
  agentRelevance  Float    @default(0)
  projectRelevance Float   @default(0)
  pinned          Float    @default(0)
  collectionWeight Float   @default(0)
  executionSuccess Float   @default(0)
  finalScore      Float    @default(0)
  factors         Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([finalScore])
}

model ContextSummary {
  id          String   @id @default(uuid())
  sessionId   String?
  session     ContextSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId      String
  conversationId String?
  projectId   String?
  kind        String   @default("conversation")
  originalTokens Int   @default(0)
  summaryTokens  Int   @default(0)
  summary     String
  sourceIds   Json     @default("[]")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, kind])
  @@index([conversationId])
  @@index([sessionId])
}

model CompressionHistory {
  id             String   @id @default(uuid())
  sessionId      String
  session        ContextSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  method         String
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  ratio          Float    @default(1.0)
  details        Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@index([method])
}

model RankingMetrics {
  id          String   @id @default(uuid())
  sessionId   String
  session     ContextSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key         String
  value       Float
  unit        String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([sessionId, key])
}

/// Phase 5 — Knowledge Engine (Memory & RAG v2)
model KnowledgeNode {
  id              String   @id @default(uuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceType      String
  sourceId        String?
  content         String
  contentHash     String?
  scope           String   @default("USER")
  importance      Float    @default(0.5)
  pinned          Boolean  @default(false)
  confidence      Float    @default(1.0)
  frequency       Int      @default(0)
  decay           Float    @default(0.0)
  archived        Boolean  @default(false)
  tags            String[] @default([])
  metadata        Json     @default("{}")
  tokenCount      Int      @default(0)
  projectId       String?
  conversationId  String?
  documentId      String?
  agentType       String?
  workspaceId     String?
  collectionId    String?
  collection      KnowledgeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  parentId        String?
  parent          KnowledgeNode? @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        KnowledgeNode[] @relation("NodeHierarchy")
  embeddingId     String?
  embedding       Embedding? @relation(fields: [embeddingId], references: [id], onDelete: SetNull)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastAccessed    DateTime @default(now())

  edgesFrom       KnowledgeEdge[] @relation("KnowledgeFrom")
  edgesTo         KnowledgeEdge[] @relation("KnowledgeTo")
  citations       Citation[]

  @@index([ownerId, sourceType])
  @@index([ownerId, scope])
  @@index([ownerId, deletedAt])
  @@index([ownerId, pinned])
  @@index([ownerId, archived])
  @@index([sourceType, sourceId])
  @@index([projectId])
  @@index([documentId])
  @@index([contentHash])
  @@index([collectionId])
}

model KnowledgeEdge {
  id         String   @id @default(uuid())
  fromId     String
  toId       String
  type       String
  weight     Float    @default(1.0)
  metadata   Json     @default("{}")
  ownerId    String
  createdAt  DateTime @default(now())

  from       KnowledgeNode @relation("KnowledgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to         KnowledgeNode @relation("KnowledgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@index([ownerId])
  @@index([type])
  @@unique([fromId, toId, type])
}

model Embedding {
  id             String   @id @default(uuid())
  contentHash    String
  model          String
  provider       String
  dimension      Int      @default(1536)
  version        Int      @default(1)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  nodes          KnowledgeNode[]
  versions       EmbeddingVersion[]

  @@index([contentHash, model])
  @@index([model, version])
}

model EmbeddingVersion {
  id          String   @id @default(uuid())
  embeddingId String
  embedding   Embedding @relation(fields: [embeddingId], references: [id], onDelete: Cascade)
  version     Int
  model       String
  provider    String
  dimension   Int
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@unique([embeddingId, version])
  @@index([embeddingId])
}

model Retrieval {
  id              String   @id @default(uuid())
  ownerId         String
  query           String
  mode            String   @default("hybrid")
  topK            Int      @default(10)
  threshold       Float    @default(0.12)
  resultCount     Int      @default(0)
  latencyMs       Int?
  indexUsed       String?
  embeddingModel  String?
  distanceMetric  String   @default("cosine")
  filters         Json     @default("{}")
  results         Json     @default("[]")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  citations       Citation[]

  @@index([ownerId, createdAt])
  @@index([mode])
}

model SearchHistory {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  query       String
  mode        String   @default("hybrid")
  resultCount Int      @default(0)
  latencyMs   Int?
  filters     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([ownerId, createdAt])
}

model Citation {
  id              String   @id @default(uuid())
  retrievalId     String?
  retrieval       Retrieval? @relation(fields: [retrievalId], references: [id], onDelete: SetNull)
  nodeId          String?
  node            KnowledgeNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  sourceType      String
  sourceId        String?
  content         String
  confidence      Float    @default(0)
  similarity      Float    @default(0)
  page            Int?
  chunkIndex      Int?
  documentName    String?
  filePath        String?
  repository      String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([retrievalId])
  @@index([nodeId])
  @@index([sourceType, sourceId])
}

model KnowledgeCollection {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  pinned      Boolean  @default(false)
  isShared    Boolean  @default(false)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nodes       KnowledgeNode[]

  @@index([ownerId])
}

model GraphMetrics {
  id          String   @id @default(uuid())
  ownerId     String
  nodeCount   Int      @default(0)
  edgeCount   Int      @default(0)
  avgDegree   Float    @default(0)
  density     Float    @default(0)
  clusters    Int      @default(0)
  metadata    Json     @default("{}")
  computedAt  DateTime @default(now())

  @@index([ownerId, computedAt])
}

model KnowledgeJob {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  status      String    @default("queued")
  progress    Float     @default(0)
  stage       String?
  error       String?
  retries     Int       @default(0)
  maxRetries  Int       @default(3)
  payload     Json      @default("{}")
  result      Json?
  deadLetter  Boolean   @default(false)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([type, status])
}

/// Phase 6 — Workspace Intelligence / Repository Intelligence Platform
model Repository {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name            String
  rootPath        String?
  languageStats   Json     @default("{}")
  techInventory   Json     @default("[]")
  healthScore     Float    @default(100)
  indexStatus     String   @default("idle")
  indexProgress   Float    @default(0)
  filesIndexed    Int      @default(0)
  symbolsIndexed  Int      @default(0)
  depsIndexed     Int      @default(0)
  lastIndexedAt   DateTime?
  indexError      String?
  summary         String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  files                 RepositoryFile[]
  symbols               Symbol[]
  references            Reference[]
  dependencies          Dependency[]
  architectureSnapshots ArchitectureSnapshot[]
  codeMetrics           CodeMetric[]
  componentGraphs       ComponentGraph[]
  apiGraphs             ApiGraph[]
  callGraphs            CallGraph[]
  importGraphs          ImportGraph[]
  workspaceMemories     WorkspaceMemory[]
  indexJobs             RepoIndexJob[]

  @@index([ownerId])
  @@index([indexStatus])
}

model RepositoryFile {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  projectFileId String?
  path          String
  name          String
  extension     String?
  language      String?
  isFolder      Boolean  @default(false)
  parentPath    String?
  contentHash   String?
  sizeBytes     Int      @default(0)
  lineCount     Int      @default(0)
  complexity    Float    @default(0)
  exports       Json     @default("[]")
  imports       Json     @default("[]")
  metadata      Json     @default("{}")
  indexedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  symbols       Symbol[]
  references    Reference[] @relation("RefFile")

  @@unique([repositoryId, path])
  @@index([repositoryId, language])
  @@index([repositoryId, isFolder])
  @@index([contentHash])
}

model Symbol {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  fileId        String
  file          RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  name          String
  kind          String
  signature     String?
  startLine     Int      @default(1)
  endLine       Int      @default(1)
  startCol      Int      @default(0)
  endCol        Int      @default(0)
  exported      Boolean  @default(false)
  visibility    String   @default("public")
  parentSymbol  String?
  documentation String?
  typeInfo      String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referencesFrom Reference[] @relation("RefFrom")
  referencesTo   Reference[] @relation("RefTo")

  @@index([repositoryId, name])
  @@index([repositoryId, kind])
  @@index([fileId])
  @@index([name, kind])
}

model Reference {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  fromSymbolId  String?
  fromSymbol    Symbol?  @relation("RefFrom", fields: [fromSymbolId], references: [id], onDelete: Cascade)
  toSymbolId    String?
  toSymbol      Symbol?  @relation("RefTo", fields: [toSymbolId], references: [id], onDelete: Cascade)
  fileId        String?
  file          RepositoryFile? @relation("RefFile", fields: [fileId], references: [id], onDelete: Cascade)
  kind          String
  name          String?
  line          Int      @default(1)
  column        Int      @default(0)
  context       String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([repositoryId, kind])
  @@index([fromSymbolId])
  @@index([toSymbolId])
  @@index([fileId])
  @@index([name])
}

model Dependency {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  fromPath      String
  toPath        String
  kind          String   @default("import")
  specifier     String?
  isExternal    Boolean  @default(false)
  isCircular    Boolean  @default(false)
  weight        Float    @default(1)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@unique([repositoryId, fromPath, toPath, kind])
  @@index([repositoryId, kind])
  @@index([repositoryId, isCircular])
  @@index([fromPath])
  @@index([toPath])
}

model ArchitectureSnapshot {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  version       Int      @default(1)
  summary       String?
  layers        Json     @default("[]")
  patterns      Json     @default("[]")
  conventions   Json     @default("{}")
  techStack     Json     @default("[]")
  diagrams      Json     @default("{}")
  violations    Json     @default("[]")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([repositoryId, createdAt])
}

model CodeMetric {
  id            String   @id @default(uuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  path          String?
  symbolName    String?
  metricType    String
  value         Float
  severity      String   @default("info")
  message       String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([repositoryId, metricType])
  @@index([repositoryId, severity])
  @@index([path])
}

model ComponentGraph {
