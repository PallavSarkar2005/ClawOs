# Required — app will fail to start if missing or weak (<32 chars / known defaults)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/clawos
JWT_SECRET=generate-a-random-64-char-string-here-min-32
JWT_REFRESH_SECRET=generate-a-different-random-64-char-string
ENCRYPTION_KEY=generate-another-random-64-char-encryption-key

# Network
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Optional
# COOKIE_SECURE=true
# WORKSPACE_ROOT=
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=7
